# Copy this file to .env.local and fill in your Supabase credentials.
# Get these from: https://app.supabase.com → your project → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Your email address — only this account gets pre-loaded with seed/demo data.
# All other users start with a blank slate.
VITE_OWNER_EMAIL=your-email@example.com
